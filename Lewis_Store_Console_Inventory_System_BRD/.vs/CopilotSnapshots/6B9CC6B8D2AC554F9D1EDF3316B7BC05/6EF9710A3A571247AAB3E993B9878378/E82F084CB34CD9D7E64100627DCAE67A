using Spectre.Console;
using System;
using System.Data.SqlClient;

public class Product
{
    public int ProductID { get; private set; }
    public string Name { get; private set; }
    public string Description { get; private set; }

    private int _quantity;
    public int Quantity
    {
        get => _quantity;
        set
        {
            if (value >= 0)
            {
                _quantity = value;
            }
            else
            {
                throw new ArgumentOutOfRangeException(nameof(Quantity), "Quantity cannot be negative.");
            }
        }
    }

    private decimal _priceExclVAT;
    public decimal PriceExclVAT
    {
        get => _priceExclVAT;
        set
        {
            if (value >= 0)
            {
                _priceExclVAT = value;
            }
            else
            {
                throw new ArgumentOutOfRangeException(nameof(PriceExclVAT), "Price cannot be negative.");
            }
        }
    }


    public Product(int productid, string name, string desc, int qty, decimal price)
	{
        ProductID = productid;
        Name = name;
        Description = desc;
        Quantity = qty;
        PriceExclVAT = price;
	}

    public void AddProduct()
    {
        var db = new DatabaseManager();
        db.AddProduct(Name, Description, Quantity, PriceExclVAT);
    }

}

